# ClawBots Polymarket Bot — Configuration Template
# ──────────────────────────────────────────────────
# On Replit: add secrets via Tools → Secrets, NOT this file.
# Locally: copy to config/.env and fill in values.

# === REQUIRED ===
# Your Polygon wallet private key (0x-prefixed, 66 chars)
POLY_PRIVATE_KEY=

# === TRADING MODE ===
# true = safe simulation only (default). Set false only for live trading.
DRY_RUN=true

# === CAPITAL SETTINGS (calibrated for $10 USDT account) ===
# Default investment per arbitrage opportunity
DEFAULT_TRADE_SIZE_USD=2
# Hard cap per single position (30% of $10 capital)
MAX_POSITION_USD=3
# Stop adding positions when total open exposure reaches this
MAX_TOTAL_EXPOSURE_USD=8

# === SAFETY LIMITS ===
# Hard-stop daily loss limit (20% of $10)
MAX_DAILY_LOSS_USD=2
# Minimum mispricing edge (%) required to enter a trade
MIN_EDGE_PCT=2.0
# Maximum number of concurrent arb positions (YES+NO pairs = 1)
MAX_OPEN_POSITIONS=4

# === SCANNING ===
# Seconds between market scans
SCAN_INTERVAL_SEC=120
# Minimum 24h volume ($) for a market to be considered
MIN_MARKET_VOLUME=500
# Categories to scan (comma-separated): crypto,politics,sports,finance,culture,geopolitics
SCAN_CATEGORIES=crypto,politics,sports,finance

# === AUTO-REDEMPTION ===
# Automatically redeem winning shares to USDC when markets resolve
AUTO_REDEEM=true
# Check for redeemable positions every N scans
REDEEM_CHECK_INTERVAL=5

# === API ENDPOINTS (defaults are correct — only change if Polymarket changes them) ===
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# === POLYGON RPC (optional — defaults to public endpoint) ===
POLYGON_RPC_URL=https://polygon-rpc.com

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
