# Polymarket Trading Bot Configuration

# === REQUIRED ===
# Your Polygon wallet private key (with 0x prefix)
POLY_PRIVATE_KEY=

# === TRADING MODE ===
# Set to false ONLY when you're ready to trade with real money
DRY_RUN=true

# === SAFETY LIMITS ===
# Maximum USD to risk on a single position
MAX_POSITION_USD=50
# Stop trading if daily losses exceed this amount
MAX_DAILY_LOSS_USD=20
# Minimum mispricing edge (%) required to enter a trade
MIN_EDGE_PCT=3.0
# Maximum number of open positions at once
MAX_OPEN_POSITIONS=10

# === SCANNING ===
# Seconds between market scans
SCAN_INTERVAL_SEC=60
# Categories to scan (comma-separated): crypto, politics, sports, finance, culture, geopolitics
SCAN_CATEGORIES=crypto,politics,sports,finance

# === API ===
# Polymarket API endpoints (defaults are fine)
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# === LOGGING ===
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log