# ── ClawBots Polymarket Bot — Environment Variables ────────────────────────
# Copy to .env (or add to Replit Secrets) and fill in your values.

# === Wallet ===
POLY_PRIVATE_KEY=0x...your_64_hex_chars_here...

# === Trading Mode ===
DRY_RUN=true                  # Set false for LIVE trading

# === Capital ===
MAX_POSITION_USD=3
DEFAULT_TRADE_SIZE_USD=2
MAX_TOTAL_EXPOSURE_USD=200
MAX_DAILY_LOSS_USD=20

# === Risk Controls ===
MAX_OPEN_POSITIONS=4
MAX_CONCURRENT_POSITIONS=10
TRAILING_STOP_PCT=30.0
POSITION_COOLDOWN_MINUTES=360

# === Auto-Compound ===
AUTO_COMPOUND=false
COMPOUND_PCT=0.20

# === Scanning ===
SCAN_INTERVAL_SEC=120
SCAN_CATEGORIES=crypto,politics,sports,finance
MIN_MARKET_VOLUME=500

# ── Strategy Toggles ────────────────────────────────────────────────────────
MISPRICING_ENABLED=true
NEAR_RESOLVED_ENABLED=true
CORRELATED_ARB_ENABLED=true
LIQUIDITY_SNIPE_ENABLED=true

# ── Mispricing ──────────────────────────────────────────────────────────────
MIN_EDGE_PCT=2
AGGRESSIVE_EDGE=5
CONSERVATIVE_EDGE=1
MIN_LIQUIDITY_USD=5000
MAX_SPREAD_PCT=2

# ── Near-Resolved ───────────────────────────────────────────────────────────
NEAR_RESOLVED_MIN_EDGE=3
NEAR_RESOLVED_MAX_HOURS=4
NEAR_RESOLVED_AUTO_EXIT=true

# ── Correlated Arbitrage ─────────────────────────────────────────────────────
CORRELATED_MIN_DIVERGENCE=5
CORRELATED_SCAN_EVERY=5
CORRELATED_MAX_POSITIONS=3

# ── Liquidity Snipe ──────────────────────────────────────────────────────────
SNIPER_ENABLED=true
SNIPER_TIER1_PRICE=0.01
SNIPER_TIER1_PCT=50
SNIPER_TIER2_PRICE=0.02
SNIPER_TIER2_PCT=30
SNIPER_TIER3_PRICE=0.03
SNIPER_TIER3_PCT=20
ENDCYCLE_ENABLED=true
ENDCYCLE_MIN_MOVEMENT=0.5
ENDCYCLE_POSITION_USD=25
CRASH_REBOUND_ENABLED=true
CRASH_REBOUND_DROP_THRESHOLD=15
CRASH_REBOUND_HOLD_HOURS=6

# === Fee ===
FEE_EDGE_MULT=1.5

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# === Auto-Redeem ===
AUTO_REDEEM=true
REDEEM_CHECK_INTERVAL=5
